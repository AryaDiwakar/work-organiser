{
  "framework": "nextjs",
  "buildCommand": "npx prisma db push --accept-data-loss && npx prisma generate && next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "env": {
    "NEXTAUTH_URL": "https://{{VERCEL_URL}}"
  }
}
